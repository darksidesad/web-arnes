---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import AgentCard from '../components/AgentCard.astro';
import BootstrapViewer from '../components/BootstrapViewer.astro';
import LoopDiagram from '../components/LoopDiagram.astro';
import ConversationExample from '../components/ConversationExample.astro';
import SectionHeader from '../components/SectionHeader.astro';
import GradientSeparator from '../components/GradientSeparator.astro';

const agents = [
  {
    name: 'Product Owner',
    icon: '📋',
    responsibility: 'Define QUÉ se construye y por qué. Genera el PRD, Definition of Done y reglas de orquestación.',
    files: ['docs/PRD.md', 'docs/DOD.md', 'AGENTS.md'],
    noGen: 'código fuente, Dockerfiles, tests, arquitectura técnica'
  },
  {
    name: 'Architect',
    icon: '🏗️',
    responsibility: 'Define CÓMO se construye. Diseña la arquitectura y configura los agentes de opencode.',
    files: ['docs/architecture.md', '.opencode/agents/orchestrator.md', '.opencode/agents/developer.md', '.opencode/agents/qa.md', '.opencode/agents/devops.md', '.opencode/skills/*/SKILL.md'],
    noGen: 'código fuente, tests, configuración de infraestructura'
  },
  {
    name: 'Developer',
    icon: '💻',
    responsibility: 'Implementa el código funcional con type hints, async/await, docstrings y manejo explícito de errores.',
    files: ['src/**/*.py', 'requirements.txt', '.env.example'],
    noGen: 'Dockerfiles, docker-compose, scripts de deploy, tests'
  },
  {
    name: 'DevOps',
    icon: '🔧',
    responsibility: 'Configura infraestructura y entornos. Docker, scripts y archivos de configuración.',
    files: ['.gitignore', 'Dockerfile', 'docker-compose.yml', 'scripts/start.sh', 'scripts/migrate.sh', 'scripts/test.sh'],
    noGen: 'código fuente, tests, documentación de negocio'
  },
  {
    name: 'QA',
    icon: '🧪',
    responsibility: 'Valida que todo funciona. Genera tests unitarios, de integración y end-to-end.',
    files: ['tests/unit/**', 'tests/integration/**', 'tests/e2e/**', 'docs/critique_vN.md'],
    noGen: 'código fuente de la aplicación, Dockerfiles'
  }
];

const steps = [
  { number: '1', title: 'Copia el Bootstrap', description: 'Copia el contenido del Bootstrap que encontraste en la sección anterior.' },
  { number: '2', title: 'Pégalo en tu chat', description: 'Inicia una nueva conversación con tu modelo de IA y pega el Bootstrap.' },
  { number: '3', title: 'Describe tu proyecto', description: 'El agente te hará preguntas y luego ejecutará el flujo completo.' },
];
---

<Layout title="Harness Engineering - Sistema de Agentes de IA">
  <div class="flex w-full flex-col items-center">
    <Hero />

    <section id="agentes" class="section">
      <div class="container md:px-16">
        <SectionHeader
          label="/agents"
          title="Los 5 Agentes"
          description="Cada agente tiene una responsabilidad específica y genera solo los archivos que le corresponden."
        />

        <div class="grid grid-cols-1 items-stretch gap-6 md:grid-cols-2 lg:grid-cols-3">
          {agents.map((agent) => (
            <AgentCard {...agent} />
          ))}
        </div>
      </div>
    </section>

    <GradientSeparator />

    <section id="bootstrap" class="section section-alt">
      <div class="container">
        <SectionHeader
          label="/bootstrap"
          title="El Bootstrap"
          description="El prompt completo que inicia el flujo de agentes. Copia y ejecuta para cada proyecto."
        />
        <BootstrapViewer />
      </div>
    </section>

    <GradientSeparator />

    <section id="loop" class="section">
      <div class="container">
        <SectionHeader
          label="/loop"
          title="Loop de Crítica"
          description="Cuando el QA encuentra errores, se activa un ciclo de corrección automático."
        />
        <LoopDiagram />
      </div>
    </section>

    <GradientSeparator />

    <section id="ejemplo" class="section section-alt">
      <div class="container">
        <SectionHeader
          label="/ejemplo"
          title="Ejemplo de Conversación"
          description="Así se ve un flujo completo de Harness Engineering en acción."
        />
        <ConversationExample />
      </div>
    </section>

    <GradientSeparator />

    <section id="empezar" class="section">
      <div class="container-narrow">
        <SectionHeader
          label="/start"
          title="Cómo Empezar"
          description="Tres pasos para usar Harness Engineering en tu próximo proyecto."
        />

        <div class="mb-12 grid grid-cols-1 gap-8 md:grid-cols-3">
          {steps.map((step) => (
            <div class="card text-center">
              <div class="step-number">{step.number}</div>
              <h3 class="mb-2 font-display text-lg font-bold text-text">{step.title}</h3>
              <p class="text-sm text-muted">{step.description}</p>
            </div>
          ))}
        </div>

        <div class="text-center">
          <button id="copy-bootstrap" class="btn-primary" type="button">
            Copiar Bootstrap Completo
          </button>
        </div>
      </div>
    </section>
  </div>
</Layout>

<script>
  const bootstrapContent = `BOOTSTRAP PROMPT - Harness Engineering v2.0

Cuando recibas un nuevo proyecto, ejecuta el siguiente flujo en orden estricto.
No avances al siguiente paso sin completar el anterior.


PASO 0: Validación del Brief

Antes de ejecutar cualquier agente, responde estas 4 preguntas al usuario:

- ¿Qué problema resuelve este proyecto en una oración?
- ¿Cuáles son los 3 riesgos técnicos principales?
- ¿Qué está explícitamente fuera del scope?
- ¿Cuál es el criterio mínimo para considerar el proyecto "entregable"?

Regla: Si el usuario no confirma o corrige, NO avances al PASO 1.
Formato de confirmación esperado: "Confirmo" o correcciones específicas.


PASO 1: Product Owner Agent

Responsabilidad: Definir QUÉ se construye y por qué.

Genera estos archivos:
  docs/PRD.md
  docs/DOD.md
  AGENTS.md

⛔ NO genera: código fuente, Dockerfiles, tests, arquitectura técnica.


PASO 2: Architect Agent

Responsabilidad: Definir CÓMO se construye.

Genera estos archivos:
  docs/architecture.md
  .opencode/agents/orchestrator.md
  .opencode/agents/developer.md
  .opencode/agents/qa.md
  .opencode/agents/devops.md
  .opencode/skills/*/SKILL.md

⛔ NO genera: código fuente, tests, configuración de infraestructura.


PASO 3: Developer Agent

Responsabilidad: Implementar el código funcional.

Reglas:
  - Type hints en todas las funciones
  - async/await para toda operación de I/O
  - Docstrings en clases y funciones públicas
  - Manejo explícito de errores
  - Cero placeholders

⛔ NO genera: Dockerfiles, docker-compose, scripts de deploy, tests.


PASO 4: DevOps Agent

Responsabilidad: Configurar infraestructura y entornos.

Genera:
  - .gitignore completo
  - Dockerfile optimizado
  - docker-compose.yml con healthchecks
  - scripts/start.sh, scripts/migrate.sh, scripts/test.sh

⛔ NO genera: código fuente, tests, documentación de negocio.


PASO 5: QA Agent

Responsabilidad: Validar que todo funciona.

Protocolo:
  Fase 5.0 — Preguntas de contexto (máximo 5 preguntas)
  Genera tests en tests/unit/, tests/integration/, tests/e2e/
  Ejecuta pytest --tb=short -q
  Si hay fallos → genera docs/critique_vN.md
  Criterio de salida: 0 errores en pytest

⛔ NO genera: código fuente de la aplicación, Dockerfiles.


LOOP DE CRÍTICA

Se activa cuando el PASO 5 encuentra errores.

Paso A — Revisar todos los archivos
Paso B — Documentar en docs/critique_vN.md
Paso C — Corregir cada problema
Paso D — Validar con pytest
Paso E — Si 3 iteraciones sin éxito → escalar al usuario

Máximo 3 iteraciones antes de escalar.`;

  document.getElementById('copy-bootstrap')?.addEventListener('click', () => {
    navigator.clipboard.writeText(bootstrapContent).then(() => {
      const btn = document.getElementById('copy-bootstrap');
      if (btn) {
        const originalText = btn.textContent;
        btn.textContent = '¡Copiado!';
        btn.classList.add('is-copied');
        setTimeout(() => {
          btn.textContent = originalText;
          btn.classList.remove('is-copied');
        }, 2000);
      }
    });
  });
</script>
