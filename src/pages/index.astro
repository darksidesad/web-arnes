---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import AgentCard from '../components/AgentCard.astro';
import BootstrapViewer from '../components/BootstrapViewer.astro';
import LoopDiagram from '../components/LoopDiagram.astro';
import ConversationExample from '../components/ConversationExample.astro';
import SectionHeader from '../components/SectionHeader.astro';
import GradientSeparator from '../components/GradientSeparator.astro';

const agents = [
  {
    name: 'Product Owner',
    icon: '📋',
    responsibility: 'Define QUÉ se construye y por qué. Genera el PRD, Definition of Done y reglas de orquestación.',
    files: ['docs/PRD.md', 'docs/DOD.md', 'AGENTS.md'],
    noGen: 'código fuente, Dockerfiles, tests, arquitectura técnica'
  },
  {
    name: 'Architect',
    icon: '🏗️',
    responsibility: 'Define CÓMO se construye. Diseña la arquitectura y configura los agentes de opencode.',
    files: ['docs/architecture.md', '.opencode/agents/orchestrator.md', '.opencode/agents/developer.md', '.opencode/agents/qa.md', '.opencode/agents/devops.md', '.opencode/skills/*/SKILL.md'],
    noGen: 'código fuente, tests, configuración de infraestructura'
  },
  {
    name: 'Developer',
    icon: '💻',
    responsibility: 'Implementa el código funcional con type hints, async/await, docstrings y manejo explícito de errores.',
    files: ['src/**/*.py', 'requirements.txt', '.env.example'],
    noGen: 'Dockerfiles, docker-compose, scripts de deploy, tests'
  },
  {
    name: 'DevOps',
    icon: '🔧',
    responsibility: 'Configura infraestructura y entornos. Docker, scripts y archivos de configuración.',
    files: ['.gitignore', 'Dockerfile', 'docker-compose.yml', 'scripts/start.sh', 'scripts/migrate.sh', 'scripts/test.sh'],
    noGen: 'código fuente, tests, documentación de negocio'
  },
  {
    name: 'QA',
    icon: '🧪',
    responsibility: 'Valida que todo funciona. Genera tests unitarios, de integración y end-to-end.',
    files: ['tests/unit/**', 'tests/integration/**', 'tests/e2e/**', 'docs/critique_vN.md'],
    noGen: 'código fuente de la aplicación, Dockerfiles'
  }
];

const steps = [
  { number: '1', title: 'Copia el Bootstrap', description: 'Copia el contenido del Bootstrap que encontraste en la sección anterior.' },
  { number: '2', title: 'Pégalo en tu chat', description: 'Inicia una nueva conversación con tu modelo de IA y pega el Bootstrap.' },
  { number: '3', title: 'Describe tu proyecto', description: 'El agente te hará preguntas y luego ejecutará el flujo completo.' },
];
---

<Layout title="Harness Engineering - Sistema de Agentes de IA">
  <div class="flex w-full flex-col items-center">
    <Hero />

    <section id="agentes" class="section">
      <div class="container md:px-16">
        <SectionHeader
          label="/agents"
          title="Los 5 Agentes"
          description="Cada agente tiene una responsabilidad específica y genera solo los archivos que le corresponden."
        />

        <div class="grid grid-cols-1 items-stretch gap-6 md:grid-cols-2 lg:grid-cols-3">
          {agents.map((agent) => (
            <AgentCard {...agent} />
          ))}
        </div>
      </div>
    </section>

    <GradientSeparator />

    <section id="bootstrap" class="section section-alt">
      <div class="container">
        <SectionHeader
          label="/bootstrap"
          title="El Bootstrap"
          description="El prompt completo que inicia el flujo de agentes. Copia y ejecuta para cada proyecto."
        />
        <BootstrapViewer />
      </div>
    </section>

    <GradientSeparator />

    <section id="loop" class="section">
      <div class="container">
        <SectionHeader
          label="/loop"
          title="Loop de Crítica"
          description="Cuando el QA encuentra errores, se activa un ciclo de corrección automático."
        />
        <LoopDiagram />
      </div>
    </section>

    <GradientSeparator />

    <section id="ejemplo" class="section section-alt">
      <div class="container">
        <SectionHeader
          label="/ejemplo"
          title="Ejemplo de Conversación"
          description="Así se ve un flujo completo de Harness Engineering en acción."
        />
        <ConversationExample />
      </div>
    </section>

    <GradientSeparator />

    <section id="empezar" class="section">
      <div class="container-narrow">
        <SectionHeader
          label="/start"
          title="Cómo Empezar"
          description="Tres pasos para usar Harness Engineering en tu próximo proyecto."
        />

        <div class="mb-12 grid grid-cols-1 gap-8 md:grid-cols-3">
          {steps.map((step) => (
            <div class="card text-center">
              <div class="step-number">{step.number}</div>
              <h3 class="mb-2 font-display text-lg font-bold text-text">{step.title}</h3>
              <p class="text-sm text-muted">{step.description}</p>
            </div>
          ))}
        </div>

        <div class="text-center">
          <button id="copy-bootstrap" class="btn-primary" type="button">
            Copiar Bootstrap Completo
          </button>
        </div>
      </div>
    </section>
  </div>
</Layout>

<script>
  const bootstrapContent = `BOOTSTRAP + LOOP ENGINEERING

Cuando recibas un nuevo proyecto, ejecuta este flujo en orden estricto.
No avances al siguiente paso sin completar el anterior y sin que el usuario confirme.

---

## FASE 0: BRIEF Y STACK DECISION

### Preguntas al usuario (máximo 8):

1. ¿Qué problema resuelve este proyecto en una oración?
2. ¿Cuáles son los 3 riesgos técnicos principales?
3. ¿Qué está explícitamente fuera del scope?
4. ¿Cuál es el criterio mínimo para considerar el proyecto "entregable"?
5. Frontend: React / Next.js / Vue / Svelte / Otro?
6. Backend: Python (FastAPI/Flask) / Node (Express/Nest) / Go / Otro?
7. Database: PostgreSQL / MySQL / MongoDB / Supabase / Redis / Ninguna?
8. Deploy: Vercel / Railway / Docker / AWS / GCP?

**Regla:** Si el usuario no confirma o corrige, NO avances.
**Formato de confirmación:** "Confirmo" o correcciones específicas.

### Genera:
- \`docs/BRIEF.md\` con las respuestas del usuario
- \`docs/STACK.md\` con las decisiones técnicas
- \`.env.example\` con variables base

---

## FASE 1: CREACIÓN (Harness Engineering)

### Skills obligatorias por paso:

| Paso | Skills | Condición |
|------|--------|-----------|
| 1 | \`obra/superpowers@brainstorming\` | Siempre |
| 2 | \`arvindrk/extract-design-system@extract-design-system\` | Siempre |
| 2 | \`shadcn/ui@shadcn\` | Si hay UI web |
| 3 | \`vercel-labs/agent-skills@vercel-react-best-practices\` | Si React/Next.js |
| 3 | \`anthropics/skills@frontend-design\` | Si hay componentes UI |
| 3 | \`supabase/agent-skills@supabase-postgres-best-practices\` | Si PostgreSQL |
| 5 | \`mattpocock/skills@tdd\` | Siempre |
| 5 | \`obra/superpowers@systematic-debugging\` | Siempre |

### Instalar skills faltantes (ejecutar si no están instaladas):
\`\`\`bash
npx skills add obra/superpowers@brainstorming -g -y
npx skills add mattpocock/skills@to-prd -g -y
npx skills add mattpocock/skills@tdd -g -y
npx skills add obra/superpowers@systematic-debugging -g -y
npx skills add mattpocock/skills@diagnose -g -y
npx skills add juliusbrussee/caveman@caveman-review -g -y
npx skills add shadcn/ui@shadcn -g -y
npx skills add vercel-labs/agent-skills@vercel-react-best-practices -g -y
npx skills add anthropics/skills@frontend-design -g -y
npx skills add supabase/agent-skills@supabase-postgres-best-practices -g -y
npx skills add arvindrk/extract-design-system@extract-design-system -g -y
\`\`\`

---

### PASO 1: Product Owner Agent

**Responsabilidad:** Definir QUÉ se construye y por qué.
**Skill:** \`obra/superpowers@brainstorming\`

Preguntar al usuario (si el brief no es claro):
1. ¿Quiénes son los usuarios principales?
2. ¿Cuál es el flujo principal del usuario?
3. ¿Hay restricciones de tiempo o presupuesto?
4. ¿Hay dependencias con sistemas externos?

**Genera:**
- \`docs/PRD.md\` — Requisitos del producto
- \`docs/DOD.md\` — Definition of Done (criterios de aceptación)
- \`docs/USER_FLOWS.md\` — Flujos de usuario principales
- \`AGENTS.md\` — Índice central del proyecto

**NO genera:** código fuente, Dockerfiles, tests, arquitectura técnica.

---

### PASO 2: Architect Agent

**Responsabilidad:** Definir CÓMO se construye.
**Skill:** \`arvindrk/extract-design-system@extract-design-system\`

**Genera:**
- \`docs/architecture.md\` — Diagrama de componentes + decisiones
- \`docs/ADR-001.md\` — Architecture Decision Records
- \`.opencode/agents/orchestrator.md\`
- \`.opencode/agents/developer.md\`
- \`.opencode/agents/qa.md\`
- \`.opencode/agents/devops.md\`
- \`.opencode/skills/*/SKILL.md\` — Skills reutilizables
- \`package.json\` o \`pyproject.toml\` — Dependencias reales
- \`.env.example\` — Variables de entorno completas

**Template architecture.md:**
\`\`\`markdown
# Architecture

## Stack
- Frontend: [tecnología]
- Backend: [tecnología]
- DB: [tecnología]
- Auth: [tecnología]

## Components
[Diagrama en Mermaid o ASCII]

## Data Flow
[Flujo de datos principal]

## Security
- [ ] Variables de entorno no expuestas
- [ ] CORS configurado
- [ ] Rate limiting
- [ ] Input validation

## Performance Targets
- API response: <200ms p95
- Bundle size: <200KB (gzipped)
\`\`\`

**NO genera:** código fuente, tests, configuración de deploy.

---

### PASO 3: Developer Agent

**Responsabilidad:** Implementar el código funcional.
**Skills:** Según stack (ver tabla arriba)

**Reglas:**
- Type hints en todas las funciones
- async/await para toda operación de I/O
- Docstrings en clases y funciones públicas
- Manejo explícito de errores
- Cero placeholders
- NO hardcodear API keys ni secrets
- Usar variables de entorno para configuración sensible
- Validar inputs con Pydantic (Python) o Zod (TypeScript)

**Antes de generar código:**
1. Leer \`docs/STACK.md\`
2. Leer \`docs/architecture.md\`
3. Cargar skill relevante del stack

**Genera también:**
- \`README.md\` con instrucciones de setup
- Comments explicativos solo en lógica compleja

**NO genera:** Dockerfiles, docker-compose, scripts de deploy, tests.

---

### PASO 4: DevOps Agent

**Responsabilidad:** Configurar infraestructura y entornos.

**Genera:**
- \`.gitignore\` completo
- \`Dockerfile\` optimizado (multi-stage si aplica)
- \`docker-compose.yml\` con healthchecks
- \`scripts/start.sh\`, \`scripts/migrate.sh\`, \`scripts/test.sh\`
- \`.env.example\` actualizado con todas las variables

**NO genera:** código fuente, tests, documentación de negocio.

---

### PASO 5: QA Agent

**Responsabilidad:** Validar que todo funciona.
**Skills:** \`mattpocock/skills@tdd\` + \`obra/superpowers@systematic-debugging\`

**Fase 5.0 — Contexto:**
Preguntar (máximo 5):
1. ¿Framework de testing? (pytest / jest / vitest)
2. ¿Coverage mínimo? (default: 80%)
3. ¿Tests E2E necesarios? (Playwright / Cypress)
4. ¿Edge cases específicos del negocio?
5. ¿Datos de prueba disponibles?

**Fase 5.1 — Unit Tests:**
- \`tests/unit/\` — Cada función pública tiene al menos 1 test
- Happy path + edge cases + error cases

**Fase 5.2 — Integration Tests:**
- \`tests/integration/\` — Tests de API endpoints
- Tests de base de datos (si aplica)

**Fase 5.3 — E2E Tests (si aplica):**
- \`tests/e2e/\` — Flujo completo del usuario principal

**Fase 5.4 — Security Check:**
- [ ] No hay secrets hardcoded
- [ ] Variables de entorno en .env.example
- [ ] Dependencias sin CVEs conocidos
- [ ] Input validation en todos los endpoints

**Fase 5.5 — Ejecución:**
- Ejecutar \`pytest --tb=short -q\` (o equivalente)
- Si hay fallos → LOOP DE CRÍTICA

**Criterio de salida:** 0 errores en tests + security check pass

**NO genera:** código fuente de la aplicación, Dockerfiles.

---

## FASE 2: MEJORA ITERATIVA (Loop Engineering)

Después de la creación inicial, aplica este loop HASTA que el proyecto esté completo.

### LOOP 1: Diagnóstico
**Skill:** \`mattpocock/skills@diagnose\`

- Revisa todos los archivos del proyecto
- Identifica qué falta, qué está incompleto
- Lista de tareas pendientes

### LOOP 2: Crítica Interna
**Skill:** \`juliusbrussee/caveman@caveman-review\`

Pregúntate como QA Agent:
- ¿Qué archivos tienen código incompleto o placeholder?
- ¿Qué funcionalidades no están implementadas?
- ¿Hay imports rotos o dependencias faltantes?
- ¿Los tests cubren los casos principales?
- ¿La documentación refleja el código real?
- ¿Hay vulnerabilidades de seguridad?

**Genera:** \`docs/critique_vN.md\` (N = iteración actual)

### LOOP 3: Investigación Dirigida
- Lee cada archivo del proyecto
- Identifica gaps específicos
- Consulta documentación de las tecnologías usadas
- Busca mejores prácticas para cada componente

### LOOP 4: Refinamiento
Implementa TODAS las correcciones encontradas:
- Completa código faltante
- Arregla imports y dependencias
- Agrega tests faltantes
- Actualiza documentación
- Agrega manejo de errores
- Implementa validación de inputs
- Corrige vulnerabilidades de seguridad

### LOOP 5: Validación
- Ejecuta suite completa de tests
- Verifica que no hay errores de sintaxis
- Confirma que la estructura está completa
- Revisa que \`.env.example\` tiene todas las variables
- Confirma que \`Dockerfile\` funciona

**Si hay errores → volver al LOOP 2**
**Si todo pasa → PRE-ENTREGA**

---

## FASE 3: PRE-ENTREGA

Antes de declarar el proyecto completo, verificar:

### Code Quality:
- [ ] Cero errores de linting
- [ ] Type hints completos
- [ ] Docstrings en funciones públicas
- [ ] Sin TODOs ni FIXMEs pendientes

### Security:
- [ ] No hay secrets en código fuente
- [ ] .env.example tiene todas las variables
- [ ] .gitignore excluye .env y secrets

### Documentation:
- [ ] README.md con setup instructions
- [ ] docs/STACK.md actualizado
- [ ] docs/architecture.md actualizado

### Infrastructure:
- [ ] Dockerfile funciona (si aplica)
- [ ] docker-compose levanta correctamente (si aplica)
- [ ] Scripts ejecutan sin errores

### Testing:
- [ ] Tests pasan al 100%
- [ ] Coverage ≥ 80%
- [ ] No hay tests pendientes

---

## FASE 4: ENTREGA

Genera \`docs/DELIVERY.md\` con:
1. Resumen de lo entregado
2. Lista de archivos generados
3. Instrucciones de ejecución
4. Known issues / pendientes
5. Siguientes pasos recomendados

---

## REGLAS GENERALES

- Cada agente solo genera archivos de su responsabilidad
- Todo código debe ser copy-paste ejecutable (no pseudocódigo)
- Máximo 5 iteraciones de loop engineering
- Si después de 5 loops hay errores críticos, reportar al usuario
- Cada loop debe ser documentado en \`docs/loop_history.md\`
- El agente DEBE cargar sus skills antes de ejecutar cada paso
- Si un skill no está instalado, instalarlo antes de continuar
- El usuario debe confirmar antes de avanzar entre FASES

## FORMATO DE CONFIRMACIÓN

Entre fases, esperar:
- "Confirmo" → avanzar
- Correcciones específicas → ajustar y re-preguntar
- "Skip [paso]" → saltar solo si el usuario lo pide explícitamente`;

  document.getElementById('copy-bootstrap')?.addEventListener('click', () => {
    navigator.clipboard.writeText(bootstrapContent).then(() => {
      const btn = document.getElementById('copy-bootstrap');
      if (btn) {
        const originalText = btn.textContent;
        btn.textContent = '¡Copiado!';
        btn.classList.add('is-copied');
        setTimeout(() => {
          btn.textContent = originalText;
          btn.classList.remove('is-copied');
        }, 2000);
      }
    });
  });
</script>
