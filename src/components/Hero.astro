---
---

<section id="hero" class="section relative w-full overflow-hidden py-24 md:py-32">
  <div class="hero-glow" aria-hidden="true"></div>
  <div class="container relative z-10 flex flex-col items-center text-center">
    <h1 class="mb-6 max-w-4xl font-display text-5xl font-bold leading-tight text-text md:text-7xl">
      Construye proyectos completos<br />
      con <span class="text-accent">agentes de IA</span>
    </h1>
    <p class="mb-10 max-w-2xl text-lg leading-relaxed text-muted md:text-xl">
      Harness Engineering es un sistema de 5 agentes especializados que trabajan en secuencia para generar código funcional, tests que pasan y documentación real — no pseudocódigo.
    </p>
    <a href="#bootstrap" class="btn-primary text-lg">
      Ver el Bootstrap
    </a>

    <div class="mt-16 flex w-full justify-center px-6">
      <svg
        viewBox="0 0 1000 180"
        class="h-[180px] w-full max-w-[900px] min-h-[180px]"
        xmlns="http://www.w3.org/2000/svg"
        aria-label="Pipeline de agentes: Product Owner, Architect, Developer, DevOps, QA"
        role="img"
      >
        <path
          d="M 165 90 L 235 90"
          stroke="var(--color-accent)"
          stroke-width="2"
          stroke-dasharray="200"
          stroke-dashoffset="200"
          marker-end="url(#arrowhead)"
          class="animate-draw"
          style="animation-delay: 0.3s"
        />
        <path
          d="M 365 90 L 435 90"
          stroke="var(--color-accent)"
          stroke-width="2"
          stroke-dasharray="200"
          stroke-dashoffset="200"
          marker-end="url(#arrowhead)"
          class="animate-draw"
          style="animation-delay: 0.6s"
        />
        <path
          d="M 565 90 L 635 90"
          stroke="var(--color-accent)"
          stroke-width="2"
          stroke-dasharray="200"
          stroke-dashoffset="200"
          marker-end="url(#arrowhead)"
          class="animate-draw"
          style="animation-delay: 0.9s"
        />
        <path
          d="M 765 90 L 835 90"
          stroke="var(--color-accent)"
          stroke-width="2"
          stroke-dasharray="200"
          stroke-dashoffset="200"
          marker-end="url(#arrowhead)"
          class="animate-draw"
          style="animation-delay: 1.2s"
        />

        <defs>
          <marker id="arrowhead" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
            <polygon points="0 0, 10 3.5, 0 7" fill="var(--color-accent)" />
          </marker>
        </defs>

        <g class="animate-fade-in" style="animation-delay: 0.2s">
          <rect x="35" y="45" width="130" height="90" rx="12" fill="var(--color-surface)" stroke="var(--color-accent)" stroke-width="1.5" />
          <text x="100" y="75" text-anchor="middle" fill="var(--color-accent)" font-size="11" font-weight="600" font-family="Space Grotesk">Product Owner</text>
          <text x="100" y="95" text-anchor="middle" fill="var(--color-muted)" font-size="10" font-family="JetBrains Mono">Define QUÉ</text>
        </g>

        <g class="animate-fade-in" style="animation-delay: 0.5s">
          <rect x="235" y="45" width="130" height="90" rx="12" fill="var(--color-surface)" stroke="var(--color-accent)" stroke-width="1.5" />
          <text x="300" y="75" text-anchor="middle" fill="var(--color-accent)" font-size="11" font-weight="600" font-family="Space Grotesk">Architect</text>
          <text x="300" y="95" text-anchor="middle" fill="var(--color-muted)" font-size="10" font-family="JetBrains Mono">Define CÓMO</text>
        </g>

        <g class="animate-fade-in" style="animation-delay: 0.8s">
          <rect x="435" y="45" width="130" height="90" rx="12" fill="var(--color-surface)" stroke="var(--color-accent)" stroke-width="1.5" />
          <text x="500" y="75" text-anchor="middle" fill="var(--color-accent)" font-size="11" font-weight="600" font-family="Space Grotesk">Developer</text>
          <text x="500" y="95" text-anchor="middle" fill="var(--color-muted)" font-size="10" font-family="JetBrains Mono">Implementa</text>
        </g>

        <g class="animate-fade-in" style="animation-delay: 1.1s">
          <rect x="635" y="45" width="130" height="90" rx="12" fill="var(--color-surface)" stroke="var(--color-accent)" stroke-width="1.5" />
          <text x="700" y="75" text-anchor="middle" fill="var(--color-accent)" font-size="11" font-weight="600" font-family="Space Grotesk">DevOps</text>
          <text x="700" y="95" text-anchor="middle" fill="var(--color-muted)" font-size="10" font-family="JetBrains Mono">Infraestructura</text>
        </g>

        <g class="animate-fade-in" style="animation-delay: 1.4s">
          <rect x="835" y="45" width="130" height="90" rx="12" fill="var(--color-surface)" stroke="var(--color-accent-2)" stroke-width="1.5" />
          <text x="900" y="75" text-anchor="middle" fill="var(--color-accent-2)" font-size="11" font-weight="600" font-family="Space Grotesk">QA</text>
          <text x="900" y="95" text-anchor="middle" fill="var(--color-muted)" font-size="10" font-family="JetBrains Mono">Valida</text>
        </g>
      </svg>
    </div>
  </div>
</section>
