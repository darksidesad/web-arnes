---
const steps = [
  { label: 'Revisar', description: 'Archivos' },
  { label: 'Documentar', description: 'critique_vN.md' },
  { label: 'Corregir', description: 'Problemas' },
  { label: 'Validar', description: 'pytest' },
];
---

<div class="py-8">
  <div class="mx-auto flex max-w-4xl flex-col items-center justify-center gap-4 md:flex-row md:gap-0">
    {steps.map((step, i) => (
      <div class="flex items-center">
        <div class="flex flex-col items-center">
          <div class="loop-step">
            <span class="mb-2 font-mono text-3xl font-bold text-accent">{'0' + (i + 1)}</span>
            <span class="font-display text-base font-bold text-text">{step.label}</span>
            <span class="mt-1 font-mono text-xs text-muted">{step.description}</span>
          </div>
        </div>

        {i < steps.length - 1 && (
          <div class="mx-4 hidden md:block">
            <svg width="48" height="24" viewBox="0 0 48 24" class="text-accent" aria-hidden="true">
              <path d="M 0 12 L 36 12" stroke="currentColor" stroke-width="2" fill="none" stroke-dasharray="6 3" />
              <polygon points="36,7 48,12 36,17" fill="currentColor" />
            </svg>
          </div>
        )}
        {i < steps.length - 1 && (
          <div class="md:hidden">
            <svg width="24" height="48" viewBox="0 0 24 48" class="text-accent" aria-hidden="true">
              <path d="M 12 0 L 12 36" stroke="currentColor" stroke-width="2" fill="none" stroke-dasharray="6 3" />
              <polygon points="7,36 12,48 17,36" fill="currentColor" />
            </svg>
          </div>
        )}
      </div>
    ))}

    <div class="flex items-center">
      <div class="mx-4 hidden md:block">
        <svg width="48" height="24" viewBox="0 0 48 24" class="text-accent" aria-hidden="true">
          <path d="M 0 12 L 36 12" stroke="currentColor" stroke-width="2" fill="none" stroke-dasharray="6 3" />
          <polygon points="36,7 48,12 36,17" fill="currentColor" />
        </svg>
      </div>
      <div class="md:hidden">
        <svg width="24" height="48" viewBox="0 0 24 48" class="text-accent" aria-hidden="true">
          <path d="M 12 0 L 12 36" stroke="currentColor" stroke-width="2" fill="none" stroke-dasharray="6 3" />
          <polygon points="7,36 12,48 17,36" fill="currentColor" />
        </svg>
      </div>

      <div class="relative">
        <div class="loop-diamond">
          <span>¿Pasa?</span>
        </div>
      </div>
    </div>
  </div>

  <div class="mx-auto mt-12 flex max-w-4xl flex-col items-center justify-center gap-24 md:flex-row">
    <div class="flex flex-col items-center">
      <span class="mb-3 font-mono text-sm font-medium text-accent">No — Repetir</span>
      <svg width="24" height="48" viewBox="0 0 24 48" class="rotate-180 text-accent md:rotate-0" aria-hidden="true">
        <path d="M 12 36 L 12 6" stroke="currentColor" stroke-width="2" fill="none" stroke-dasharray="4 2" />
        <polygon points="7,6 12,-4 17,6" fill="currentColor" />
      </svg>
      <div class="card-accent card mt-3 px-8 py-4 text-center">
        <span class="font-display text-base font-bold text-accent">Repetir</span>
        <p class="mt-1 font-mono text-xs text-muted">Máx. 3 iteraciones</p>
      </div>
    </div>

    <div class="flex flex-col items-center">
      <span class="mb-3 font-mono text-sm font-medium text-accent-2">Sí — Entregar</span>
      <svg width="24" height="48" viewBox="0 0 24 48" class="rotate-180 text-accent-2 md:rotate-0" aria-hidden="true">
        <path d="M 12 36 L 12 6" stroke="currentColor" stroke-width="2" fill="none" stroke-dasharray="4 2" />
        <polygon points="7,6 12,-4 17,6" fill="currentColor" />
      </svg>
      <div class="card-success card mt-3 px-8 py-4 text-center">
        <span class="font-display text-base font-bold text-accent-2">Entregar</span>
        <p class="mt-1 font-mono text-xs text-muted">Proyecto listo</p>
      </div>
    </div>
  </div>
</div>
