---
const steps = [
  { label: 'Revisar', description: 'Archivos', color: 'accent' },
  { label: 'Documentar', description: 'critique_vN.md', color: 'accent' },
  { label: 'Corregir', description: 'Problemas', color: 'accent' },
  { label: 'Validar', description: 'pytest', color: 'accent' },
];
---

<div class="py-8">
  <!-- Loop Diagram -->
  <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-0 max-w-4xl mx-auto">
    {steps.map((step, i) => (
      <div class="flex items-center">
        <!-- Step Box -->
        <div class="flex flex-col items-center">
          <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-6 w-36 h-36 flex flex-col items-center justify-center text-center transition-all duration-300 hover:border-[var(--color-accent)] hover:shadow-[0_0_20px_#6C63FF40]">
            <span class="text-[var(--color-accent)] text-3xl font-bold mb-2 font-['JetBrains_Mono']">{'0' + (i + 1)}</span>
            <span class="text-[var(--color-text)] font-bold text-base font-['Space_Grotesk']">{step.label}</span>
            <span class="text-[var(--color-muted)] text-xs mt-1 font-['JetBrains_Mono']">{step.description}</span>
          </div>
        </div>

        {/* Arrow between steps */}
        {i < steps.length - 1 && (
          <div class="hidden md:block mx-4">
            <svg width="48" height="24" viewBox="0 0 48 24" class="text-[var(--color-accent)]">
              <path d="M 0 12 L 36 12" stroke="currentColor" stroke-width="2" fill="none" stroke-dasharray="6 3" />
              <polygon points="36,7 48,12 36,17" fill="currentColor" />
            </svg>
          </div>
        )}
        {i < steps.length - 1 && (
          <div class="md:hidden">
            <svg width="24" height="48" viewBox="0 0 24 48" class="text-[var(--color-accent)]">
              <path d="M 12 0 L 12 36" stroke="currentColor" stroke-width="2" fill="none" stroke-dasharray="6 3" />
              <polygon points="7,36 12,48 17,36" fill="currentColor" />
            </svg>
          </div>
        )}
      </div>
    ))}

    {/* Arrow to decision */}
    <div class="flex items-center">
      <div class="hidden md:block mx-4">
        <svg width="48" height="24" viewBox="0 0 48 24" class="text-[var(--color-accent)]">
          <path d="M 0 12 L 36 12" stroke="currentColor" stroke-width="2" fill="none" stroke-dasharray="6 3" />
          <polygon points="36,7 48,12 36,17" fill="currentColor" />
        </svg>
      </div>
      <div class="md:hidden">
        <svg width="24" height="48" viewBox="0 0 24 48" class="text-[var(--color-accent)]">
          <path d="M 12 0 L 12 36" stroke="currentColor" stroke-width="2" fill="none" stroke-dasharray="6 3" />
          <polygon points="7,36 12,48 17,36" fill="currentColor" />
        </svg>
      </div>

      {/* Decision Diamond */}
      <div class="relative">
        <div class="w-36 h-36 transform rotate-45 border-2 border-[var(--color-accent)] bg-[var(--color-surface)] flex items-center justify-center shadow-[0_0_30px_#6C63FF30]">
          <span class="transform -rotate-45 text-[var(--color-accent)] font-bold text-lg font-['Space_Grotesk']">¿Pasa?</span>
        </div>
      </div>
    </div>
  </div>

  {/* Decision Branches */}
  <div class="flex flex-col md:flex-row items-center justify-center gap-24 mt-12 max-w-4xl mx-auto">
    {/* Fail Branch - Repetir */}
    <div class="flex flex-col items-center">
      <span class="text-[var(--color-accent)] text-sm font-medium mb-3 font-['JetBrains_Mono']">No — Repetir</span>
      <svg width="24" height="48" viewBox="0 0 24 48" class="text-[var(--color-accent)] md:rotate-0 rotate-180">
        <path d="M 12 36 L 12 6" stroke="currentColor" stroke-width="2" fill="none" stroke-dasharray="4 2" />
        <polygon points="7,6 12,-4 17,6" fill="currentColor" />
      </svg>
      <div class="bg-[var(--color-surface)] border border-[var(--color-accent)] rounded-xl px-8 py-4 mt-3 text-center">
        <span class="text-[var(--color-accent)] font-bold text-base font-['Space_Grotesk']">Repetir</span>
        <p class="text-[var(--color-muted)] text-xs mt-1 font-['JetBrains_Mono']">Máx. 3 iteraciones</p>
      </div>
    </div>

    {/* Success Branch - Entregar */}
    <div class="flex flex-col items-center">
      <span class="text-[var(--color-accent-2)] text-sm font-medium mb-3 font-['JetBrains_Mono']">Sí — Entregar</span>
      <svg width="24" height="48" viewBox="0 0 24 48" class="text-[var(--color-accent-2)] md:rotate-0 rotate-180">
        <path d="M 12 36 L 12 6" stroke="currentColor" stroke-width="2" fill="none" stroke-dasharray="4 2" />
        <polygon points="7,6 12,-4 17,6" fill="currentColor" />
      </svg>
      <div class="bg-[var(--color-surface)] border border-[var(--color-accent-2)] rounded-xl px-8 py-4 mt-3 text-center">
        <span class="text-[var(--color-accent-2)] font-bold text-base font-['Space_Grotesk']">Entregar</span>
        <p class="text-[var(--color-muted)] text-xs mt-1 font-['JetBrains_Mono']">Proyecto listo</p>
      </div>
    </div>
  </div>
</div>
