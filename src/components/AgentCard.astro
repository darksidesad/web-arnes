---
interface Props {
  name: string;
  icon: string;
  responsibility: string;
  files: string[];
  noGen: string;
}

const { name, icon, responsibility, files, noGen } = Astro.props;
---

<div class="card-interactive flex h-full flex-1 flex-col">
  <div class="mb-4 flex items-center gap-3">
    <span class="text-2xl" aria-hidden="true">{icon}</span>
    <h3 class="font-display text-xl font-bold text-text">{name}</h3>
  </div>
  <p class="mb-4 leading-relaxed text-muted">{responsibility}</p>
  <div class="mb-4">
    <span class="badge badge-danger">⛔ NO genera: {noGen}</span>
  </div>
  <div class="mt-auto pt-4">
    <p class="mb-2 text-xs font-medium uppercase tracking-wider text-muted">Archivos generados:</p>
    <ul class="space-y-1">
      {files.map((file) => (
        <li class="flex items-center gap-2 font-mono text-sm text-text">
          <span class="text-accent" aria-hidden="true">•</span>
          {file}
        </li>
      ))}
    </ul>
  </div>
</div>
